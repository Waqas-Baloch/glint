{
  "name": "superterminal",
  "version": "1.1.0",
  "description": "Super Terminal — one control layer for every AI coding agent. Write your rules once and they apply to Claude Code, Cursor, and ChatGPT Codex alike, and chain agents into a single workflow.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Waqas-Baloch/superterminal.git"
  },
  "homepage": "https://github.com/Waqas-Baloch/superterminal#readme",
  "bugs": "https://github.com/Waqas-Baloch/superterminal/issues",
  "keywords": [
    "cli",
    "ai",
    "ai-agent",
    "coding-agent",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "chatgpt",
    "llm",
    "developer-tools",
    "code-review",
    "multi-agent"
  ],
  "bin": {
    "super-t": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.6",
    "minisearch": "^7.2.0",
    "ora": "^9.4.1",
    "parse5": "^7.3.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^26.1.1",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
