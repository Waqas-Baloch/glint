{
  "name": "@waqasbaloch/glint",
  "version": "0.1.0",
  "description": "Glint — compress your codebase into a task-specific manifest for any AI coding agent. Precision context, fewer tokens.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Waqas-Baloch/glint.git"
  },
  "homepage": "https://github.com/Waqas-Baloch/glint#readme",
  "bugs": "https://github.com/Waqas-Baloch/glint/issues",
  "keywords": [
    "cli",
    "ai",
    "claude",
    "cursor",
    "codex",
    "context",
    "tokens",
    "code-agent",
    "llm"
  ],
  "bin": {
    "glint": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "tsup"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.6",
    "minisearch": "^7.2.0",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^26.1.1",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
